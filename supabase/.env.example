# ==========================================
# VARIABLES DE ENTORNO - SUPABASE EDGE FUNCTIONS
# ==========================================
# Este archivo es un ejemplo. Cópialo como `.env` en esta misma
# carpeta (`supabase/.env`) y completa con los valores reales para probar localmente.

# Meta / WhatsApp Cloud API
WHATSAPP_PHONE_NUMBER_ID=tu_id_de_telefono_aqui
WHATSAPP_VERIFY_TOKEN=tu_palabra_secreta_webhook_aqui
WHATSAPP_APP_SECRET=tu_secreto_de_app_aqui
WHATSAPP_ACCESS_TOKEN=tu_token_permanente_aqui

# Internal service-to-service secret (must match CRON_SECRET in Next.js .env.local)
# Required for process-whatsapp → whatsapp-service owner notifications
CRON_SECRET=tu_cron_secret_aqui

# AI / LLM Provider (Groq, OpenAI, Anthropic, etc.)
LLM_API_KEY=tu_api_key_aqui

# Sentry (observabilidad — opcional en local)
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_ENVIRONMENT=local

# LangSmith (fan-out de traces — opt-in, best-effort secundario a PgTraceSink)
# Sin LANGSMITH_API_KEY el sink degrada silenciosamente a solo Postgres.
# Las Edge Functions (Deno) NO leen el .env.local de la raíz: hay que setearla aquí
# para local y con `npx supabase secrets set LANGSMITH_API_KEY=...` para producción.
LANGSMITH_API_KEY=tu_langsmith_api_key_aqui
# Opcionales (tienen default: endpoint=https://api.smith.langchain.com, project=cronix)
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LANGSMITH_PROJECT=cronix
