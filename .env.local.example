# ==========================================
# VARIABLES DE ENTORNO - AGENDO/CRONIX
# ==========================================
# Este archivo es una plantilla. Los desarrolladores deben copiar
# este archivo como `.env.local` y llenar los valores reales.
# 
# IMPORTANTE: ¡Nunca hagas commit de tu `.env.local` real!

# ── Supabase (Base de datos y Autenticación) ──

# URL de tu proyecto de Supabase (App URL)
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto-aqui.supabase.co

# Anon key (Clave pública segura para el cliente/navegador)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR...

# Service Role Key (Requerida en backend/server actions. ¡NUNCA EXPONER AL CLIENTE!)
# Permite saltarse RLS y administrar autenticación o tareas administrativas.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_XXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# WhatsApp Cloud API (Meta)
WHATSAPP_ACCESS_TOKEN=(Pega aquí el Token largo que dura 24h)
WHATSAPP_PHONE_NUMBER_ID=(Pega aquí el Identificador de número)
WHATSAPP_BUSINESS_ACCOUNT_ID=(Pega aquí el ID de la cuenta)
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=

# Vercel Cron Secret (Para proteger tu Alarma)
CRON_SECRET=una_clave_aleatoria

# AI / LLM Provider (Groq, OpenAI, Anthropic, etc.)
LLM_API_KEY=

# ── Sentry (Observabilidad y Error Tracking) ──────────────────────────────────
# Crea tu proyecto en https://sentry.io → Settings → Projects → DSN
#
# El DSN es seguro para exponer públicamente (solo permite ESCRIBIR eventos).
# Usa el mismo valor para NEXT_PUBLIC_SENTRY_DSN y SENTRY_DSN.

# Expuesto al browser (requerido para capturar errores en el cliente)
NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Solo servidor — puede ser el mismo DSN
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# Para upload de source maps durante el build en Vercel/CI
# Genera el token en: https://sentry.io/settings/auth-tokens/
SENTRY_AUTH_TOKEN=sntrys_xxx
SENTRY_ORG=tu-organizacion-en-sentry
SENTRY_PROJECT=cronix

QSTASH_URL=""
QSTASH_TOKEN=""
QSTASH_CURRENT_SIGNING_KEY=""
QSTASH_NEXT_SIGNING_KEY=""

ELEVENLABS_VOICE_ID=""
ELEVENLABS_API_KEY=""

# ── Sentry para Edge Functions (Supabase secrets) ─────────────────────────────
# Configura estos secretos vía CLI (NO en este archivo):
#   npx supabase secrets set SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
#   npx supabase secrets set SENTRY_ENVIRONMENT=production
# SENTRY_DSN y SENTRY_ENVIRONMENT son los únicos secretos necesarios en Deno.