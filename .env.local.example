# ── SUPABASE (Required) ───────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DB_PASSWORD="your-db-password"

# ── SITE CONFIG ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── AUTH (Google) ─────────────────────────────────────────────────────────────
ID_CLIENTE_GOOGLE=your-google-client-id
SECRETO_CLIENTE_GOOGLE=your-google-client-secret

# ── WHATSAPP CLOUD API (Meta) ─────────────────────────────────────────────────
WHATSAPP_ACCESS_TOKEN=your-meta-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_BUSINESS_ACCOUNT_ID=your-business-id
WHATSAPP_APP_SECRET=your-app-secret
WHATSAPP_VERIFY_TOKEN=your-random-verification-token

# ── AI / LLM (Groq / Gemini) ──────────────────────────────────────────────────
# Primary LLM Provider (used in assistant)
LLM_API_KEY=your-groq-api-key
# Selecciona el proveedor del voice-worker: "groq" (default), "gemini", o "gemini,groq" (fallback)
LLM_PROVIDER=groq
# Requerido solo si LLM_PROVIDER incluye "gemini"
GEMINI_API_KEY=your-gemini-key


# Cerebras — 70B a velocidad de 8B, gratis. Obtén tu key en cerebras.ai
# Si está vacío, el sistema usa Groq 8B automáticamente (sin romper nada)
CEREBRAS_API_KEY=your-cerebras-api-key

# ── AUDIO / TTS (Deepgram Aura 2) ────────────────────────────────────────────
# Get your key at: https://console.deepgram.com
# Voice model: aura-2-nestor-es (Spanish male — ultra-low latency)
DEEPGRAM_AURA_API_KEY=your-deepgram-api-key

# ── PUSH NOTIFICATIONS (VAPID) ────────────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-public-key
VAPID_PRIVATE_KEY=your-private-key
VAPID_SUBJECT=mailto:soporte@TU_DOMINIO
CRON_SECRET=your-random-cron-secret

# ── OBSERVABILITY (Sentry) ────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn
SENTRY_DSN=your-sentry-dsn
SENTRY_AUTH_TOKEN=your-sentry-auth-token
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=your-sentry-project

# ── QUEUE / SCHEDULING (Upstash QStash) ───────────────────────────────────────
QSTASH_URL=https://qstash.upstash.io
QSTASH_TOKEN=your-qstash-token
QSTASH_CURRENT_SIGNING_KEY=your-signing-key
QSTASH_NEXT_SIGNING_KEY=your-next-signing-key
QSTASH_REGION="US_EAST_1"

# ── MONITORING (Helicone - Optional) ──────────────────────────────────────────
HELICONE_API_KEY=your-helicone-key

# UPSTASH REDIS
UPSTASH_REDIS_REST_URL=your-upstash-redis-url
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-token

# Axiom
NEXT_PUBLIC_AXIOM_DATASET=
AXIOM_TOKEN=

# Playwright
E2E_TEST_EMAIL=
E2E_TEST_PASSWORD=

APP_URL=

# ── PAYMENTS (NOWPayments) ────────────────────────────────────────────────────
NOWPAYMENTS_API_KEY=your-nowpayments-api-key
NOWPAYMENTS_IPN_SECRET=your-nowpayments-ipn-secret
# Para pruebas locales o staging usa: https://api.sandbox.nowpayments.io/v1
NOWPAYMENTS_API_URL=https://api.nowpayments.io/v1

# ── PAYMENTS (PayPal) ─────────────────────────────────────────────────────────
# Obtén credenciales en https://developer.paypal.com/dashboard/applications
# Usa las credenciales de Sandbox para desarrollo; Production para release.
# Si NEXT_PUBLIC_PAYPAL_CLIENT_ID queda vacío, la UI muestra un warning en lugar del botón.
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
# Webhook ID (registra el webhook en developer.paypal.com → My Apps → Webhooks
# apuntando a `${APP_URL}/api/webhooks/paypal`, suscrito a PAYMENT.CAPTURE.COMPLETED)
PAYPAL_WEBHOOK_ID=your-paypal-webhook-id
# Sandbox por defecto. Para procesar pagos reales en Live, defínela como 'live'
# (sin esto, incluso en Vercel production se usa Sandbox).
# PAYPAL_ENV=live