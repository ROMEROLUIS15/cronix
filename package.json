{
  "name": "cronix",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbo",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "typecheck": "tsc --noEmit",
    "knip": "knip",
    "check:spec-drift": "tsx scripts/check-spec-drift.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --project=smoke",
    "test:evals": "python -m pytest evals -v",
    "test:evals:rotator": "python -m pytest evals/test_groq_rotator.py -v",
    "e2e:setup": "tsx scripts/setup-e2e-data.ts",
    "sim:whatsapp": "tsx scripts/sim-whatsapp.ts",
    "trigger:voice": "tsx scripts/trigger-voice.ts",
    "seed:intents": "tsx scripts/seed-intent-embeddings.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@ducanh2912/next-pwa": "^10.2.9",
    "@paypal/react-paypal-js": "^9.2.0",
    "@rushstack/eslint-patch": "^1.16.1",
    "@sentry/nextjs": "^10.46.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.98.0",
    "@tanstack/react-query": "^5.62.0",
    "@upstash/qstash": "^2.10.1",
    "@upstash/redis": "^1.37.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.468.0",
    "next": "^15.5.15",
    "next-intl": "^4.9.1",
    "next-themes": "^0.4.6",
    "react": "^19.2.0",
    "react-day-picker": "^8.10.1",
    "react-dom": "^19.2.0",
    "react-icons": "^5.6.0",
    "recharts": "^3.8.1",
    "sharp": "^0.34.5",
    "tailwind-merge": "^2.5.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@playwright/test": "^1.59.1",
    "@supabase/mcp-server-supabase": "^0.8.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.8",
    "@vitest/ui": "^4.1.8",
    "autoprefixer": "^10.0.1",
    "dotenv": "^17.4.2",
    "eslint": "^8",
    "eslint-config-next": "^15.5.15",
    "fast-check": "^4.8.0",
    "husky": "^9.1.7",
    "jimp": "^1.6.1",
    "jsdom": "^29.0.2",
    "knip": "^5.88.1",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.10",
    "supabase": "^2.105.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.8",
    "vitest-mock-extended": "^2.0.2"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix"
    ]
  },
  "overrides": {
    "import-in-the-middle": "3.0.0",
    "postcss": "$postcss",
    "uuid": "^11.1.1",
    "serialize-javascript": "^7.0.5",
    "next-pwa": {
      "serialize-javascript": "^7.0.5"
    },
    "@ducanh2912/next-pwa": {
      "serialize-javascript": "^7.0.5",
      "workbox-build": {
        "serialize-javascript": "^7.0.5",
        "@rollup/plugin-terser": {
          "serialize-javascript": "^7.0.5"
        }
      }
    }
  },
  "security": {
    "overrides": [
      {
        "package": "serialize-javascript",
        "version": "^7.0.5",
        "reason": "Fix RCE vulnerability GHSA-5c6j-r48x-rmvq (CVSS 8.1)",
        "applied": "2026-04-12",
        "expires": "2026-07-01",
        "review": "Remove when @ducanh2912/next-pwa updates workbox-build dependency"
      }
    ]
  }
}
