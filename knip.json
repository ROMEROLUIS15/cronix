{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "scripts/**/*.{ts,js}",
    "worker/index.js",
    "i18n/**/*.ts",
    "vitest.components.config.ts",
    "__tests__/setup/test-setup.ts",
    "tests/e2e/**/*.ts"
  ],
  "ignore": [
    "supabase/functions/**",
    "types/database.types.ts",
    "lib/mock/**",
    "tests/load/**"
  ],
  "ignoreBinaries": ["python"],
  "ignoreDependencies": [
    "@rushstack/eslint-patch",
    "@typescript-eslint/eslint-plugin",
    "@vitejs/plugin-react",
    "supabase",
    "jimp",
    "@modelcontextprotocol/sdk",
    "@supabase/mcp-server-supabase"
  ],
  "ignoreExportsUsedInFile": true,
  "rules": {
    "files": "warn",
    "exports": "warn",
    "types": "warn",
    "nsExports": "warn",
    "nsTypes": "warn",
    "enumMembers": "warn",
    "duplicates": "warn",
    "classMembers": "warn",
    "dependencies": "error",
    "unlisted": "error",
    "binaries": "error",
    "unresolved": "error"
  }
}
